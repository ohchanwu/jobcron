# Compiled binaries
/jobcron
/jobcron.exe
*.exe

# GoReleaser output
/dist/

# Local runtime data (the app stores jobs.db under os.UserConfigDir())
*.db
*.db-shm
*.db-wal

# Local environment files. Production values are created directly on the server.
.env
.env.*
!.env.example
deploy/demo/.env

# 점핏 API spike material — raw captured responses kept locally as Step 4
# fixture seeds. May contain request headers / cookies. Never committed.
/internal/scraper/jumpit/API_NOTES.md
/internal/scraper/jumpit/curl-cmd-response*.txt

# Local AI-integration planning doc — interactive v2.0 design notes, kept local
# and out of git per user request (English + Korean draft).
/ai-integration-plan*.md

# Claude Code local config (settings, session state, skills)
/.claude/

# Playwright MCP screenshots (Tier C UI verification runs)
/.playwright-mcp/

# macOS
.DS_Store
.gstack/
tmp/

screenshots/

# Local research scratch notes
/docs/research/resources.md

# Local implementation artifacts and human-only handoff notes.
/.superpowers/archive/
/.worktrees/

# Terraform local artifacts. State, variable values, plans, and crash output can
# contain secrets or production identifiers; keep provider lock files tracked.
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
*.tfplan
crash.log
crash.*.log

# Local Terraform overrides and per-user CLI configuration.
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
