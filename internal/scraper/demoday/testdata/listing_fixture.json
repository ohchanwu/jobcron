    {
        "id": 16967,
        "title": "[\ucc44\uc6a9] \ub77c\ub77c\ube44\uce58 - \ube0c\ub79c\ub4dc\ub9e4\ub2c8\uc800 \uacb8 \ub9c8\ucf00\ud130",
        "content": "<figure class=\"table\"><table><tbody><tr><th>\ud68c\uc0ac\uba85</th><td>\ub77c\ub77c\ube44\uce58</td></tr><tr><th>\ud3ec\uc9c0\uc158</th><td>\ube0c\ub79c\ub4dc\ub9e4\ub2c8\uc800 \uacb8 \ub9c8\ucf00\ud130</td></tr><tr><th>\uadfc\ubb34\uc9c0</th><td>\uc11c\uc6b8 \uc11c\ucd08\uad6c \uc2e0\ubc18\ud3ec\ub85c 194</td></tr><tr><th>\uace0\uc6a9\ud615\ud0dc</th><td>\uacc4\uc57d\uc9c1</td></tr><tr><th>\uacbd\ub825</th><td>\uc2e0\uc785</td></tr></tbody></table></figure>\n\n<h2>\ud68c\uc0ac \uc18c\uac1c</h2>\n<p>\ub77c\ub77c\ube44\uce58(LALA BEACH)\ub294 \uac15\uc6d0\ub3c4 \uc18d\ucd08\u00b7\uc591\uc591\uc744 \uae30\ubc18\uc73c\ub85c \ud55c \ube44\uce58 \ub77c\uc774\ud504\uc2a4\ud0c0\uc77c \ubdf0\ud2f0 \ube0c\ub79c\ub4dc\uc785\ub2c8\ub2e4.<br>\uc11c\ud551\ud558\uace0, \ub2ec\ub9ac\uace0, \ud587\ube5b \uc544\ub798 \uc6c0\uc9c1\uc774\ub294 \uc0ac\ub78c\ub4e4\uc744 \uc704\ud55c \uc120\ucf00\uc5b4\uc640 \ubc14\ub514\ucf00\uc5b4\ub97c \ub9cc\ub4e4\uc5b4\uc694. \ub2e8\uc21c\ud788 \ud53c\ubd80\ub97c \ubcf4\ud638\ud558\ub294 \uc81c\ud488\uc774 \uc544\ub2c8\ub77c, \ud0dc\uc591\uc744 \ub9c8\uc8fc\ud558\ub294 \ud0dc\ub3c4\ub97c \ub2f4\uc740 \ube0c\ub79c\ub4dc\uc785\ub2c8\ub2e4.<br>\ud604\uc7ac \ubbf8\ub124\ub784 \uc120\ud06c\ub9bc, \ud0dc\ub2dd \uc624\uc77c, \uc6cc\ud130 \uc561\ud2f0\ube44\ud2f0 \uc6a9\ud488 \ub77c\uc778\uc744 \uc6b4\uc601 \uc911\uc774\uba70,<br>\ucfe0\ud321 \ub85c\ucf13\ubc30\uc1a1 \ub4f1 \uc8fc\uc694 \ucc44\ub110\uc5d0 \uc785\uc810\ud574 \ube0c\ub79c\ub4dc\ub97c \ube60\ub974\uac8c \ud655\uc7a5\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.</p>\n<p>\uc774 \ud3ec\uc9c0\uc158\uc740 \ub77c\ub77c\ube44\uce58\uc758 \uccab \ubc88\uc9f8 \ud300\uc6d0\uc785\ub2c8\ub2e4.</p>\n<p>\ube0c\ub79c\ub4dc \uae30\ud68d\uacfc \ub9c8\ucf00\ud305\uc744 \ud568\uaed8 \ub2f4\ub2f9\ud558\uba70, \ucea0\ud398\uc778\uc744 \uc9c1\uc811 \uae30\ud68d\ud558\uace0 \uc2e4\ud589\uae4c\uc9c0 \uc774\uc5b4\uac00\ub294 \uc5ed\ud560\uc774\uc5d0\uc694.<br>\ub300\ud45c\uc640 \ubc00\ucc29\ud574\uc11c \uc77c\ud558\uace0, \ube0c\ub79c\ub4dc\uc758 \uc5b8\uc5b4\uc640 \ubc29\ud5a5\uc744 \ud568\uaed8 \ub9cc\ub4e4\uc5b4\uac11\ub2c8\ub2e4.<br>\"\ub204\uad70\uac00\uac00 \ub9cc\ub4e4\uc5b4\ub193\uc740 \ube0c\ub79c\ub4dc\ub97c \uc6b4\uc601\"\ud558\ub294 \uc790\ub9ac\uac00 \uc544\ub2c8\ub77c,<br>\ube0c\ub79c\ub4dc\uac00 \uc138\uc0c1\uc5d0 \ubaa9\uc18c\ub9ac\ub97c \ub0b4\ub294 \uccab \uc21c\uac04\uc744 \ud568\uaed8 \ub9cc\ub4dc\ub294 \uc790\ub9ac\uc785\ub2c8\ub2e4.<br>\uc791\uc740 \ud300\uc5d0\uc11c \ub113\uac8c \uc77c\ud558\uace0, \uadf8 \uacbd\ud5d8\uc774 \uc628\uc804\ud788 \ub0b4 \ud3ec\ud2b8\ud3f4\ub9ac\uc624\uac00 \ub418\ub294 \ud658\uacbd\uc744 \uc6d0\ud558\ub294 \ubd84\uc5d0\uac8c \ub9de\ub294 \uc5ed\ud560\uc785\ub2c8\ub2e4.</p>\n\n<h2>\uc8fc\uc694 \uc5c5\ubb34</h2>\n<p>\ube0c\ub79c\ub4dc \uae30\ud68d</p>\n<p>\uc2dc\uc98c\ubcc4 \uc81c\ud488 \ucd9c\uc2dc \ucea0\ud398\uc778 \uae30\ud68d \ubc0f \uc2e4\ud589 (\uc36c\ucf00\uc5b4, \uc560\ud504\ud130\ucf00\uc5b4 \ub4f1)<br>\uc790\uc0ac\ubab0(Cafe24) \ube0c\ub79c\ub4dc \ucf58\ud150\uce20 \uae30\ud68d \ubc0f \uc6b4\uc601<br>\ube0c\ub79c\ub4dc \uc570\ubc30\uc11c\ub354(\ub7ec\ub108\u00b7\uc0ac\uc774\ud074\u00b7\ud14c\ub2c8\uc2a4\u00b7\uc11c\ud37c) \uad00\uacc4 \uc6b4\uc601 \ubc0f \ucf58\ud150\uce20 \ud611\uc5c5 \uc870\uc728<br>\uc678\uc8fc \ud30c\ud2b8\ub108(\ub514\uc790\uc778\u00b7\uc601\uc0c1) \ube0c\ub9ac\ud551 \ubc0f \ud53c\ub4dc\ubc31 \uad00\ub9ac</p>\n<p>\ub9c8\ucf00\ud305 \uc2e4\ud589</p>\n<p>\uc778\uc2a4\ud0c0\uadf8\ub7a8 \ucc44\ub110 \uae30\ud68d\u00b7\uc6b4\uc601 (\ucf58\ud150\uce20 \uae30\ud68d, \uce74\ud53c \uc791\uc131, \ubc1c\ud589 \uc2a4\ucf00\uc904 \uad00\ub9ac)<br>Meta \ub4f1 SNS \uad11\uace0 \uae30\ucd08 \uc6b4\uc601 \ubc0f \uc131\uacfc \ubd84\uc11d<br>\ub808\uc800 \ucee4\ubba4\ub2c8\ud2f0, \ud31d\uc5c5 \ub4f1 \uc624\ud504\ub77c\uc778 \uc811\uc810 \uc2e4\ud589 \uc9c0\uc6d0<br>VOC \uc218\uc9d1\u00b7\ubd84\uc11d \ubc0f \ube0c\ub79c\ub4dc \uac1c\uc120 \ud53c\ub4dc\ubc31 \ub8e8\ud504 \uc6b4\uc601</p>\n\n<h2>\uc790\uaca9\uc694\uac74</h2>\n<p>\ube0c\ub79c\ub4dc \uae30\ud68d \ub610\ub294 \ub9c8\ucf00\ud305 \uc2e4\ubb34 \uacbd\ud5d8 \uc6b0\ub300 (\uc778\ud558\uc6b0\uc2a4 \ub610\ub294 \ub300\ud589\uc0ac)<br>\ube0c\ub79c\ub4dc \uc5b8\uc5b4\uc640 \uce74\ud53c\ub77c\uc774\ud305\uc5d0 \uac10\uac01\uc774 \uc788\ub294 \ubd84<br>\uae30\ud68d\ubd80\ud130 \uc2e4\ud589\uae4c\uc9c0 \uc2a4\uc2a4\ub85c \uc6c0\uc9c1\uc774\ub294 \ubc29\uc2dd\uc5d0 \uc775\uc219\ud55c \ubd84<br>\uc8fc 1\ud68c \ub300\uba74 \ubbf8\ud305 \uac00\ub2a5\ud55c \ubd84(\uc11c\uc6b8/\uc138\uc885)</p>\n\n<h2>\uc6b0\ub300\uc0ac\ud56d</h2>\n<p>\uc11c\ud551\u00b7\ub7ec\ub2dd\u00b7\uc0ac\uc774\ud074\u00b7\ud14c\ub2c8\uc2a4 \ub4f1 \uc561\ud2f0\ube0c \ub77c\uc774\ud504\uc2a4\ud0c0\uc77c\uc744 \uc9c1\uc811 \uc990\uae30\ub294 \ubd84<br>\uc778\uc2a4\ud0c0\uadf8\ub7a8 \ucf58\ud150\uce20 \uae30\ud68d\u00b7\uc6b4\uc601 \uc2e4\uc801 \ubcf4\uc720<br>Cafe24 \ub610\ub294 \uc790\uc0ac\ubab0 \uc6b4\uc601 \uacbd\ud5d8<br>\ub77c\uc774\ud504\uc2a4\ud0c0\uc77c\u00b7\ubdf0\ud2f0 \ube0c\ub79c\ub4dc \uc778\ud558\uc6b0\uc2a4 \uacbd\ud5d8</p>\n\n<h2>\ubcf5\uc9c0 \ubc0f \ud61c\ud0dd</h2>\n<p>\uae09\uc5ec</p>\n<p>\uae30\ubcf8 \uc5f0\ubd09 2,800\ub9cc\uc6d0<br>\uc5f0\uac04 \ubaa9\ud45c \ub2ec\uc131\ub960\uc5d0 \ub530\ub77c \ucd5c\ub300 \uae30\ubcf8\uae09 10% \ucd94\uac00 \uc9c0\uae09</p>\n<p>\uadfc\ubb34 \ud658\uacbd<br>\uc644\uc804 \uc7ac\ud0dd\uadfc\ubb34<br>\uc790\uc728 \ucd9c\ud1f4\uadfc (\ucf54\uc5b4\ud0c0\uc784 10:30~17:00)<br>\ud31d\uc5c5\u00b7\ub808\uc800 \ud589\uc0ac\u00b7\ucd2c\uc601 \ub4f1 \ud604\uc7a5 \ucd9c\uc7a5\ube44 \uc804\uc561 \uc9c0\uc6d0</p>\n<p>\ud734\uac00</p>\n<p>\ubc95\uc815 \uc5f0\ucc28 \uc678 \ud558\uacc4 \uc6cc\ucf00\uc774\uc158 \uc9c0\uc6d0<br>\ub3d9\uacc4 \ud734\uac00 1\uc8fc\uc77c \ubcc4\ub3c4 \uc81c\uacf5</p>\n<p>\uc131\uc7a5</p>\n<p>\ub300\ud45c \uc9c1\uc18d \u2014 \ube0c\ub79c\ub4dc \ub860\uce6d \uc804 \uacfc\uc815\uc744 \ud568\uaed8\ud558\ub294 \ud658\uacbd<br>\ube0c\ub79c\ub4dc \uccab \ubc88\uc9f8 \ud300\uc6d0\uc73c\ub85c\uc11c \ud3ec\ud2b8\ud3f4\ub9ac\uc624 \uacf5\ub3d9 \uad6c\uc131<br>\uc131\uacfc\uc5d0 \ub530\ub978 \uc9c1\ucc45 \ubd80\uc5ec (\ube0c\ub79c\ub4dc\ub9e4\ub2c8\uc800 / \ube0c\ub79c\ub4dc \ub514\ub809\ud130) \uba85\uc2dc\uc801 \uacbd\ub85c \ubcf4\uc7a5</p>\n\n<h2>\uc9c0\uc6d0 \ubc29\ubc95</h2>\n<p><a href=\"https://www.wanted.co.kr/wd/363766\" target=\"_blank\" rel=\"noopener noreferrer\">\uc6d0\ud2f0\ub4dc\uc5d0\uc11c \uc9c0\uc6d0\ud558\uae30</a></p>",
        "excerpt": "<p>\ub77c\ub77c\ube44\uce58(LALA BEACH)\ub294 \uac15\uc6d0\ub3c4 \uc18d\ucd08\u00b7\uc591\uc591\uc744 \uae30\ubc18\uc73c\ub85c \ud55c \ube44\uce58 \ub77c\uc774\ud504\uc2a4\ud0c0\uc77c \ubdf0\ud2f0 \ube0c\ub79c\ub4dc\uc785\ub2c8\ub2e4.<br>\uc11c\ud551\ud558\uace0, \ub2ec\ub9ac\uace0, \ud587\ube5b \uc544\ub798 \uc6c0\uc9c1\uc774\ub294 \uc0ac\ub78c\ub4e4\uc744 \uc704\ud55c \uc120\ucf00\uc5b4\uc640 \ubc14\ub514\ucf00\uc5b4\ub97c \ub9cc\ub4e4\uc5b4\uc694. \ub2e8\uc21c\ud788 \ud53c\ubd80\ub97c \ubcf4\ud638\ud558\ub294 \uc81c\ud488\uc774 \uc544\ub2c8\ub77c, \ud0dc\uc591\uc744 \ub9c8\uc8fc\ud558\ub294 \ud0dc\ub3c4\ub97c \ub2f4\uc740 \ube0c\ub79c\ub4dc\uc785\ub2c8\ub2e4.<br>\ud604\uc7ac \ubbf8\ub124\ub784 \uc120\ud06c\ub9bc, \ud0dc\ub2dd \uc624\uc77c, \uc6cc\ud130 \uc561\ud2f0\ube44\ud2f0 \uc6a9\ud488 \ub77c\uc778\uc744 \uc6b4\uc601 \uc911\uc774\uba70,",
